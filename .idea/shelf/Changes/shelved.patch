@@ -0,0 +1,27 @@
+interface ProductPageProps {
+    params: Promise<{
+        id: string;
+    }>;
+}
+
+const products = [
+    { id: "1", name: "Ноутбук" },
+    { id: "2", name: "Смартфон" },
+    { id: "3", name: "Планшет" },
+];
+
+export default async function ProductPage({ params }: ProductPageProps) {
+    const { id } = await params;
+
+    const product = products.find((p) => p.id === id);
+
+    if (!product) {
+        return <h1>Товар не найден</h1>;
+    }
+
+    return (
+        <main>
+            <h1>{product.name}</h1>
+        </main>
+    );
+}
